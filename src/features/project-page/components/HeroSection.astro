---
const { hero } = Astro.props;
---
<section id="hero" class="hero">
  <div class="hero-copy">
    <p class="eyebrow">
      <a href={hero.eyebrow.href} target={hero.eyebrow.external ? "_blank" : undefined} rel={hero.eyebrow.external ? "noreferrer" : undefined}>
        {hero.eyebrow.label}
      </a>
    </p>
    <h1>{hero.title}</h1>
    <div class="authors-inline">
      {hero.authors.map((author) => (
        <span set:html={author}></span>
      ))}
    </div>
    <p class="author-note" set:html={hero.authorNote}></p>
    <div class="affiliations">
      {hero.affiliations.map((item) => (
        <span>{item}</span>
      ))}
    </div>
    <div class="hero-actions">
      <div class="cta-row">
        {hero.actions.map((action, index) => (
          <a
            class={`cta ${index === 0 ? "primary" : "cta-secondary"}`}
            href={action.href}
            target={action.external ? "_blank" : undefined}
            rel={action.external ? "noreferrer" : undefined}
          >
            {action.label}
          </a>
        ))}
      </div>
      <div class="repo-stat-row" aria-label="GitHub repository stars">
        {hero.repoStats?.map((repo) => (
          <a
            class="repo-stat"
            href={repo.href}
            target="_blank"
            rel="noreferrer"
            aria-label={repo.label}
            data-repo-owner={repo.repoOwner}
            data-repo-name={repo.repoName}
          >
            <span class="repo-stat-icon" aria-hidden="true">
              <svg viewBox="0 0 16 16" role="img" focusable="false">
                <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.5 7.5 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8 8 0 0 0 16 8c0-4.42-3.58-8-8-8Z"></path>
              </svg>
            </span>
            <span class="repo-stat-text">{repo.shortLabel}</span>
            <span class="repo-stat-star" aria-hidden="true">
              <svg viewBox="0 0 16 16" role="img" focusable="false">
                <path d="m8 1.2 1.9 3.86 4.26.62-3.08 3 0.73 4.24L8 10.93l-3.81 2 0.73-4.24-3.08-3 4.26-.62L8 1.2Z"></path>
              </svg>
            </span>
            <span class="repo-stat-count" data-repo-count>...</span>
          </a>
        ))}
      </div>
    </div>
  </div>
  <div class="hero-media">
    <div class="video-frame">
      <video
        class="teaser-video"
        src={hero.teaserVideoSrc}
        aria-label={hero.teaserVideoAlt}
        autoplay
        controls
        muted
        loop
        playsinline
        preload="auto"
      ></video>
    </div>
  </div>
</section>

<script is:inline>
  const formatRepoStars = (count) => {
    if (count >= 1000) {
      const compact = count >= 10000 ? Math.round(count / 1000) : Math.round(count / 100) / 10;
      return `${compact}k`;
    }
    return `${count}`;
  };

  const hydrateRepoStars = async () => {
    const repoLinks = Array.from(document.querySelectorAll(".repo-stat[data-repo-owner][data-repo-name]"));
    if (!repoLinks.length) return;

    await Promise.all(repoLinks.map(async (link) => {
      const owner = link.getAttribute("data-repo-owner");
      const repo = link.getAttribute("data-repo-name");
      const countNode = link.querySelector("[data-repo-count]");
      if (!owner || !repo || !countNode) return;

      try {
        const response = await fetch(`https://api.github.com/repos/${owner}/${repo}`, {
          headers: { Accept: "application/vnd.github+json" },
        });
        if (!response.ok) throw new Error(`GitHub API returned ${response.status}`);

        const data = await response.json();
        countNode.textContent = formatRepoStars(data.stargazers_count ?? 0);
      } catch {
        countNode.textContent = "GitHub";
      }
    }));
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", hydrateRepoStars, { once: true });
  } else {
    hydrateRepoStars();
  }
</script>
